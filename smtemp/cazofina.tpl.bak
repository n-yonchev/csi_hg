<a href="caseeditzone.php{$elem.prin}" class="nyroModal" target="_blank"><img src="images/print.gif" title="НРОЕВЮРХ ойн"></a>
<a href="#" onclick="fuprin('caseeditzone.php{$elem.prin}');"><img src="images/print.gif" title="НРОЕВЮРХ ойн"></a>
***}
<a href="#" onclick="fuprin('{$elem.prin}');"><img src="images/print.gif" title="НРОЕВЮРХ ойн"></a>
