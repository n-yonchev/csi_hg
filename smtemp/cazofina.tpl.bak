							{assign var=flprin value=false}
							{assign var=flinfo value=false}
														{*---- цкнаюкем ткюц - МЮАКЧДЮРЕК ----*}
{*
{foreach from=$smarty.session item=itse key=kese}
	sess={$kese}={$itse}
	<br>
{/foreach}
*}
