				{if $flinfo}
<img src="images/info.gif" class="info" rel="caseeditzone.php{$elem.info}" title="ХМТНПЛЮЖХЪ ГЮ ОПХЙКЧВЕМН ОНЯРЗОКЕМХЕ" style="cursor:help">
