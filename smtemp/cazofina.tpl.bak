							{assign var=flinfo value=true}
				{else}
					{*---- МЕОПХЙКЧВЕМН ----*}
					{if $elem.idtype==2}
						{*---- ОПХУ.ЙЮЯНБ НПДЕП ----*}
							{assign var=fledit value=true}
							{assign var=flprin value=true}
					{else}
						{*---- НЯРЮМЮКХРЕ РХОНБЕ ----*}
						{if $FLAGNOCHANGE and !$FINALOGGED}
							{*---- МЪЛЮ ОПЮБЮ ГЮ ЙНПЕЙЖХЪ ----*}
						{else}
							{*---- ХЛЮ ОПЮБЮ ГЮ ЙНПЕЙЖХЪ ----*}
							{assign var=fledit value=true}
						{/if}
					{/if}
				{/if}
														{/if}

				{*---- ЙКЕРЙЮРЮ Я ХЙНМХ - ЯОНПЕД ЯЗЯРНЪМХЕРН МЮ ТКЮЦНБЕРЕ ----*}
		<td class='sep'>&nbsp;</td>
<td align=left>
<nobr>
				{if $fledit}
<a href="caseeditzone.php{$elem.edit}" class="nyroModal" target="_blank"><img src="images/edit.png" title="ЙНПЕЦХПЮИ"></a>
